# ============================================================
# Backend - Variáveis de Ambiente
# ============================================================

# Banco de Dados
# Para MySQL local:
DB_URL=jdbc:mysql://localhost:3306/cursinhoinsercao
DB_USER=root
DB_PASSWORD=sua_senha_aqui

# Para NeonDB (PostgreSQL) em produção:
# DB_URL=jdbc:postgresql://ep-xxxxx.sa-east-1.aws.neon.tech/cursinhoinsercao?sslmode=require
# DB_USER=neondb_owner
# DB_PASSWORD=sua_senha_neon

# JWT - gere uma chave com: openssl rand -base64 32
JWT_SECRET=

# CORS - origins permitidas (separadas por vírgula)
# Em produção, coloque a URL da Vercel:
# CORS_ALLOWED_ORIGINS=https://seu-projeto.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Porta do servidor
SERVER_PORT=8080

# Hibernate SQL logging (true/false)
HIBERNATE_SHOW_SQL=false
